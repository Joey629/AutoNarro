# 复制为 .env 并填入你的 DeepSeek API Key（勿提交 .env）
# cp .env.example .env

DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选：对外部署时限制 API 访问
# NARRO_API_KEY=
# NARRO_ADMIN_API_KEY=
# NARRO_REQUIRE_API_KEY=1
# NARRO_TENANT_ID=default
# NARRO_CORS_ORIGINS=https://your.domain
# NARRO_HTTPS=1

# 默认模型栈（与 configs/model_registry.json 的 active_version 一致）
NARRO_MODEL_VERSION=narro_v4
