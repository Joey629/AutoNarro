# 复制为 .env 并填入你的 DeepSeek API Key（勿提交 .env）
# cp .env.example .env

DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 豆包语音（PN agent 小乐 TTS）— 火山引擎控制台开通后填写
# https://console.volcengine.com/speech/app
#
# 新版控制台（推荐）：只需 API Key（UUID 格式），可写在下面任一项
# VOLC_TTS_API_KEY=your-api-key
# VOLC_TTS_ACCESS_TOKEN=your-api-key
#
# 旧版控制台：需要 App ID + Access Token 成对填写
# VOLC_TTS_APP_ID=your-app-id
# VOLC_TTS_ACCESS_TOKEN=your-access-token
#
# VOLC_TTS_VOICE=BV051_streaming
# VOLC_TTS_RESOURCE_ID=seed-tts-1.0
# VOLC_TTS_CLUSTER=volcano_tts

# 可选：对外部署时限制 API 访问
# NARRO_API_KEY=
# 内置管理员（默认账号 admin / 密码 123456，登录后可见「平台数据」）
# NARRO_ADMIN_LOGIN=admin
# NARRO_ADMIN_PASSWORD=123456
# NARRO_ADMIN_EMAILS=extra-admin@example.com
# NARRO_ADMIN_API_KEY=
# NARRO_REQUIRE_API_KEY=1
# NARRO_TENANT_ID=default
# NARRO_CORS_ORIGINS=https://your.domain
# NARRO_HTTPS=1

# 默认模型栈（与 configs/model_registry.json 的 active_version 一致）
NARRO_MODEL_VERSION=narro_v4
